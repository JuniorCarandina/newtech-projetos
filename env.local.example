@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #0d1b2a;
  --bg2:     #1b263b;
  --bg3:     #112240;
  --card:    #16233a;
  --border:  rgba(255,255,255,.08);
  --gold:    #f59e0b;
  --text:    #e5e7eb;
  --muted:   #4b6fa0;
  --muted2:  #3d5a80;
}

html, body {
  background: linear-gradient(135deg, var(--bg) 0%, var(--bg2) 50%, var(--bg) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'Barlow Condensed', sans-serif;
  color: var(--text);
}

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: #2a3f5f; border-radius: 3px; }

/* Inputs dark global */
input, select, textarea {
  font-family: 'Barlow Condensed', sans-serif;
  background: var(--bg3) !important;
  color: var(--text) !important;
  border: 1px solid var(--border) !important;
  transition: border-color .15s;
}
input::placeholder, textarea::placeholder { color: var(--muted2) !important; }
input:focus, select:focus, textarea:focus {
  outline: none !important;
  border-color: var(--gold) !important;
  box-shadow: 0 0 0 2px rgba(245,158,11,.15) !important;
}
option { background: var(--bg3) !important; }

/* Buttons */
.btn {
  border: none; border-radius: 8px; padding: 9px 16px;
  cursor: pointer; font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; font-weight: 700;
  display: inline-flex; align-items: center; gap: 6px;
  transition: all .15s; white-space: nowrap;
}
.btn:hover { opacity: .85; transform: translateY(-1px); }
.btn-primary   { background: var(--gold);  color: #000; }
.btn-secondary { background: rgba(255,255,255,.07); color: #94a3b8; border: 1px solid var(--border) !important; }
.btn-purple    { background: #7c3aed; color: #fff; }
.btn-danger    { background: rgba(239,68,68,.15); color: #ef4444; }
.btn-icon      { background: rgba(255,255,255,.07); color: #94a3b8; border: 1px solid var(--border) !important; padding: 9px; }
